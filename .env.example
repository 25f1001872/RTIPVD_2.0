# ==============================================================
# RTIPVD — Environment Variables Template
# ==============================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These are loaded by the application at runtime.
# ==============================================================

# -----------------------------
# Core Runtime
# -----------------------------
RTIPVD_DEVICE=cuda:0
RTIPVD_VIDEO_SOURCE=data/videos/d1.mp4
RTIPVD_MODEL_PATH=weights/best.pt
RTIPVD_TRACKER_CONFIG=config/bytetrack.yaml
RTIPVD_USE_MOCK_OCR=false
RTIPVD_OCR_USE_GPU=true
RTIPVD_SHOW_DISPLAY=true

# -----------------------------
# Database
# -----------------------------
RTIPVD_DB_ENABLED=true
RTIPVD_DB_PATH=output/db/rtipvd.db
RTIPVD_DB_MERGE_WINDOW_SECONDS=120

# -----------------------------
# GPS (ESP32 + NEO-6M)
# IMPORTANT: Mock GPS values must be in DECIMAL DEGREES (pre-converted from ddmm.mmmm format)
# Example: raw 2951.6747 → converts to 29.861245; raw 7753.8555 → converts to 77.897592
# Serial NMEA parsing handles this automatically; mock values should already be decimal.
# -----------------------------
RTIPVD_GPS_ENABLED=false
RTIPVD_GPS_SOURCE=serial
RTIPVD_GPS_SERIAL_PORT=/dev/ttyUSB0
RTIPVD_GPS_BAUD_RATE=9600
RTIPVD_GPS_READ_TIMEOUT_MS=300
RTIPVD_GPS_MOCK_LAT=29.861245
RTIPVD_GPS_MOCK_LON=77.897592

# -----------------------------
# Backend Upload
# -----------------------------
RTIPVD_BACKEND_ENABLED=false
RTIPVD_BACKEND_URL=http://127.0.0.1:5000/api/violations
RTIPVD_BACKEND_API_KEY=
RTIPVD_BACKEND_TIMEOUT_SEC=5
RTIPVD_BACKEND_VERIFY_SSL=true

# -----------------------------
# Dashboard API Server
# -----------------------------
RTIPVD_DASHBOARD_HOST=0.0.0.0
RTIPVD_DASHBOARD_PORT=5000
RTIPVD_DASHBOARD_DEBUG=false

# -----------------------------
# Stream Transport (Pi -> Laptop)
# -----------------------------
RTIPVD_STREAM_SERVER_HOST=0.0.0.0
RTIPVD_STREAM_SERVER_PORT=8088
RTIPVD_STREAM_SERVER_URL=http://127.0.0.1:8088/ingest/frame
RTIPVD_STREAM_SEND_FPS=8
RTIPVD_STREAM_JPEG_QUALITY=70
RTIPVD_STREAM_DEFAULT_HEADING_DEG=0